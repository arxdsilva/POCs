* 1. What is it?

> behind the scenes *orchestrator* of Go programs

    func main() {
        // crete goroutines
        for _, i := range imgs {
            go process(i)
        }
        ...
        // wait
        <-ch
    }
    func process(img) {
        // create another goroutine
        go createMetrics()

        complicatedAlgo(img)

        // write to file
        f, err := os.OpenFile()
        ...
    }


* 1. What is it?

> behind the scenes *orchestrator* of Go programs

    func main() {
        // crete goroutines
        for _, i := range imgs {
            go process(i)               -> *Runs* created goroutines 
        }
        ...
        // wait
        <-ch
    }
    func process(img) {
        // create another goroutine
        go createMetrics()

        complicatedAlgo(img)

        // write to file
